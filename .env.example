# SentinelForge configuration — copy to `.env` and edit.
#
#   cp .env.example .env
#
# `.env` is git-ignored. Never commit real secrets.

# --- environment -----------------------------------------------------------
# dev | test | prod
APP_ENV=dev

# --- security --------------------------------------------------------------
# The application REFUSES TO START in prod while this is the placeholder below.
# Generate a real one:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-only-insecure-secret-change-me

ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12

# Login throttling
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_MINUTES=15

# --- database --------------------------------------------------------------
# docker compose supplies this automatically; set it for a local Postgres.
DATABASE_URL=postgresql+psycopg://sentinelforge:sentinelforge@localhost:5432/sentinelforge
DATABASE_ECHO=false

# --- upload / import limits ------------------------------------------------
MAX_UPLOAD_BYTES=10485760
MAX_YAML_BYTES=524288
MAX_ZIP_ENTRIES=500
MAX_ZIP_TOTAL_UNCOMPRESSED_BYTES=52428800
MAX_ZIP_COMPRESSION_RATIO=100
MAX_DATASET_EVENTS=100000

# --- detection engine bounds ----------------------------------------------
DETECTION_MAX_EVENTS=100000
DETECTION_TIME_BUDGET_SECONDS=60
MAX_REGEX_LENGTH=1000

# --- frontend --------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000"]

# Read by apps/web at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000
